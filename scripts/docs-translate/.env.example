# Copy this file to:
# scripts/docs-translate/.env.local

# Required for checks that call a model.
KUKU_ANTHROPIC_BASE_URL="${KUKU_ANTHROPIC_BASE_URL:-}"
KUKU_ANTHROPIC_API_KEY="${KUKU_ANTHROPIC_API_KEY:-}"

# Required for helpers that create or update GitHub PRs.
# You can paste a token or uncomment the command substitution below.
GH_TOKEN="${GH_TOKEN:-}"
# GH_TOKEN="$(gh auth token 2>/dev/null || true)"
GITHUB_TOKEN="${GITHUB_TOKEN:-$GH_TOKEN}"

# Local runner settings.
KUKU_AGENT_RUNNER_IMAGE="${KUKU_AGENT_RUNNER_IMAGE:-kuku-agent-runner:local}"
KUKU_CACHE_ROOT="${KUKU_CACHE_ROOT:-/tmp/kuku/docs-translate}"
KUKU_CONTAINER_CACHE_DIR="${KUKU_CONTAINER_CACHE_DIR:-/kuku-cache}"
KUKU_CHECK_MODEL="${KUKU_CHECK_MODEL:-balanced}"
KUKU_CHECK_OUTPUT_MODE="${KUKU_CHECK_OUTPUT_MODE:-raw}"
KUKU_CHECK_SHOW_SKILL_INFO="${KUKU_CHECK_SHOW_SKILL_INFO:-0}"

# Optional: set a fixed run id when multiple helper calls should share one KUKU_HOME.
KUKU_RUN_ID="${KUKU_RUN_ID:-}"

# Optional: default arguments for translate-page-and-open-pr.sh.
KUKU_DOCS_TARGET_LOCALE="${KUKU_DOCS_TARGET_LOCALE:-}"
KUKU_DOCS_PR="${KUKU_DOCS_PR:-}"

# Optional: override the built-in run-local-check.sh prompt.
# translate-page-and-open-pr.sh always builds its own structured prompt.
KUKU_CHECK_PROMPT="${KUKU_CHECK_PROMPT:-}"
