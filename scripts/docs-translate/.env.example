# Copy the lines you need into:
# scripts/docs-translate/.env.local

# Optional: reuse your local GitHub CLI auth for gh commands inside Docker.
# GH_TOKEN="$(gh auth token 2>/dev/null || true)"
# GITHUB_TOKEN="$GH_TOKEN"

# Required for the current validation config.
# KUKU_ANTHROPIC_BASE_URL="https://your-provider.example/v1"
# KUKU_ANTHROPIC_API_KEY="your-provider-key"

# Optional override.
# KUKU_CHECK_MODEL="balanced"

# Optional custom image tag.
# KUKU_AGENT_RUNNER_IMAGE="kuku-agent-runner:local"

# Optional custom cache root.
# KUKU_CACHE_ROOT="/tmp/opencode/docs-translate"

# Optional cache mount path inside the container.
# KUKU_CONTAINER_CACHE_DIR="/kuku-cache"

# Optional explicit run id when you want multiple helper calls to share one per-run KUKU_HOME.
# KUKU_RUN_ID="manual-test-001"

# Optional target locale for the open-pr helper.
# KUKU_DOCS_TARGET_LOCALE="zh"

# Optional existing PR reference for open-pr hotfix runs.
# KUKU_DOCS_PR="46"

# Optional custom runtime check prompt.
# KUKU_CHECK_PROMPT="/docs-translate ..."

# Optional output mode: raw, json, or stream-json.
# KUKU_CHECK_OUTPUT_MODE="raw"

# Optional: show skill discovery/debug info during the container run.
# KUKU_CHECK_SHOW_SKILL_INFO="1"
